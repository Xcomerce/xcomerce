# Copie para .env.local:  cp .env.example .env.local
# O app web usa SOMENTE este arquivo — não usa o MCP do Cursor.

# --- Supabase remoto (Dashboard → Settings → API) ---
VITE_SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# --- Supabase local (opcional) ---
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=cole-a-anon-key-do-comando: supabase status

# Depois de configurar o projeto remoto, aplique o schema na raiz do repo:
#   supabase login
#   supabase link --project-ref SEU-PROJECT-REF
#   supabase db push
